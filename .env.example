# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
DEBUG=0
APP_ENV=production  # or 'development'

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_PORT=5432
DATABASE_URL=postgresql+asyncpg://hello_flask:hello_flask@db:$DATABASE_PORT/hello_flask_dev

# Supabase Configuration (set USE_SUPABASE=true to use Supabase instead of local DB)
USE_SUPABASE=true
# Use the Transaction Pooler connection string (port 6543) or Direct (port 5432)
SUPABASE_DB_URL=postgresql+asyncpg://postgres.[PROJECT_ID]:[PASSWORD]@[HOST]:[PORT]/postgres
SUPABASE_PROJECT_URL=
SUPABASE_API_KEY=
# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# For LOCAL development (Docker):
#   VITE_API_BASE_URL=http://localhost:56733
#
# For VERCEL deployment:
#   VITE_API_BASE_URL=https://your-app.vercel.app/api
#   Example: VITE_API_BASE_URL=https://fast-vue-jwt-qha3.vercel.app/api
#
VITE_API_BASE_URL=http://localhost:56733

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://frontend:8080

# -----------------------------------------------------------------------------
# Security Keys (generate secure random strings for these)
# -----------------------------------------------------------------------------
SECRET_KEY=your_production_secret_key_here
JWT_SECRET_KEY=your_production_jwt_secret_key_here

# -----------------------------------------------------------------------------
# Google OAuth Configuration
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Go to APIs & Services -> Credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add Authorized redirect URIs:
#
#    For LOCAL development:
#      http://localhost:8080/api/google/auth
#
#    For VERCEL deployment:
#      https://your-app.vercel.app/api/google/auth
#      Example: https://fast-vue-jwt-qha3.vercel.app/api/google/auth
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# OAuth redirect URI — must match what's configured in Google Cloud Console
# For LOCAL: http://localhost:8080/api/google/auth
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/google/auth

# -----------------------------------------------------------------------------
# Line OAuth Configuration
# -----------------------------------------------------------------------------
# Get these from Line Developers: https://developers.line.biz/
# 1. Go to LINE Developers Console -> Create/Select a Provider
# 2. Create a LINE Login Channel
# 3. Under "Basic settings", find Channel ID (LINE_APP_ID) and Channel secret (LINE_APP_SECRET)
# 4. Under "LINE Login" tab, add Callback URL:
#
#    For LOCAL development:
#      http://localhost:8080/api/line/auth
#
#    For VERCEL deployment:
#      https://your-app.vercel.app/api/line/auth
#
LINE_APP_ID=
LINE_APP_SECRET=
LINE_OAUTH_REDIRECT_URI=http://localhost:8080/api/line/auth

# After successful login, redirect to this frontend URL
# For LOCAL: http://localhost:8080/login-success
# For VERCEL: https://your-app.vercel.app/login-success
FRONTEND_LOGIN_SUCCESS_URI=http://localhost:8080/login-success

# -----------------------------------------------------------------------------
# Debug Mode Configuration
# -----------------------------------------------------------------------------
# Set to true to show "Debugger" button on login page
# When false, the Debugger button is hidden and role-select is inaccessible
DEBUG_MODE=false
